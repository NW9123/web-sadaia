# =============================================================================
# TripMind — Environment Variables
# =============================================================================
# The application runs fully in DEMO mode with NO variables set: all external
# integrations (AI, Places, Flights, Hotels, Weather, Currency, Maps) fall back
# to deterministic mock providers with realistic Arabic demo data.
#
# Copy this file to `.env.local` and fill in values to enable real providers.
# -----------------------------------------------------------------------------

# --- App -------------------------------------------------------------------
# Public base URL, used for share links and metadata.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Supabase (optional) ---------------------------------------------------
# When these are absent the app uses an in-memory data layer + mock auth so it
# still works end-to-end without a database.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Server-only. NEVER expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=""

# --- AI provider (optional) ------------------------------------------------
# AI_PROVIDER: "mock" (default) | "anthropic" | "openrouter"
AI_PROVIDER="mock"

# Anthropic adapter (when AI_PROVIDER="anthropic")
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-5"

# OpenRouter adapter (when AI_PROVIDER="openrouter") — OpenAI-compatible.
# Powers real trip generation + natural-language editing + destination research;
# falls back to the deterministic engine on any error. Put the real key in
# .env.local, not here. Example model: "google/gemini-3.6-flash".
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="google/gemini-3.6-flash"

# --- Live web deals (optional) ---------------------------------------------
# Enrich generated trips with REAL offers: hotels from Booking/Almosafer and
# flight booking links + fare signals from Saudia/Almosafer. Search via Tavily,
# scraping via Firecrawl. Set DEALS_PROVIDER="web" and provide at least one key
# to enable; booking links/prices are real (estimated), schedules stay demo.
DEALS_PROVIDER="off"            # "off" | "web"
TAVILY_API_KEY=""
FIRECRAWL_API_KEY=""

# --- External integrations (optional) --------------------------------------
# Each provider defaults to "mock" when its key is missing.
MAPS_PROVIDER="mock"            # "mock" | "mapbox" | "google"
NEXT_PUBLIC_MAPBOX_TOKEN=""
GOOGLE_MAPS_API_KEY=""

PLACES_PROVIDER="mock"          # "mock" | "google" | "foursquare"
FLIGHTS_PROVIDER="mock"         # "mock" | "amadeus"
HOTELS_PROVIDER="mock"          # "mock" | "amadeus" | "booking"
WEATHER_PROVIDER="mock"         # "mock" | "openweather"
CURRENCY_PROVIDER="mock"        # "mock" | "exchangerate"
